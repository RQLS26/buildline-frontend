@startuml Buildline_Class_Diagram

skinparam classAttributeIconSize 0
skinparam classFontSize 12
skinparam packageFontSize 14
skinparam linetype ortho
skinparam nodesep 60
skinparam ranksep 40

' ===================================================================
' SHARED BOUNDED CONTEXT
' ===================================================================
package "Shared" <<Rectangle>> #F0F4FF {

    package "Infrastructure" {
        class BaseApi {
            - http: AxiosInstance
            + {method} get http(): AxiosInstance
        }

        class BaseEndpoint {
            - resourceEndpoint: String
            - baseApi: BaseApi
            + {method} getAll(): Promise
            + {method} getById(id): Promise
            + {method} create(resource): Promise
            + {method} update(id, resource): Promise
            + {method} delete(id): Promise
        }

        BaseEndpoint --> BaseApi : uses
    }

    package "Presentation" {
        class LayoutComponent <<Vue Component>> {
            + sidebar: Object
            + currentRoute: String
            + {method} toggleSidebar(): void
        }

        class LanguageSwitcher <<Vue Component>> {
            + locale: String
            + {method} switchLocale(lang): void
        }

        class DashboardShellView <<Vue View>> {
            + {method} mounted(): void
        }

        class SettingsView <<Vue View>> {
            + preferences: Object
            + security: Object
        }

        class AccessDeniedView <<Vue View>>
        class PageNotFoundView <<Vue View>>
        class AboutView <<Vue View>>
    }
}

' ===================================================================
' IAM BOUNDED CONTEXT
' ===================================================================
package "IAM (Identity & Access Management)" <<Rectangle>> #FFF3E0 {

    package "Domain" {
        class User <<Entity>> {
            + id: Number
            + name: String
            + email: String
            + password: String
            + role: String
            + department: String
            + isActive: Boolean
            + avatarColor: String
            + lastLogin: String
        }
    }

    package "Infrastructure" {
        class IamApi {
            + {method} getUsers(): Promise
            + {method} registerUser(userData): Promise
        }

        class UserAssembler {
            + {static} toEntityFromResource(resource): User
            + {static} toEntitiesFromResponse(response): User[]
        }

        UserAssembler ..> User : creates
    }

    package "Application" {
        class IamStore <<Pinia Store>> {
            + currentUser: User
            + allUsers: User[]
            + isAuthenticated: Boolean
            + {method} login(email, password): Promise
            + {method} register(userData): Promise
            + {method} logout(): void
            + {method} fetchAllUsers(): Promise
            + {method} updateUserRole(id, role): Promise
            + isAdmin: Boolean
            + userRole: String
        }
    }

    package "Presentation" {
        class SignInView <<Vue View>> {
            + email: String
            + password: String
            + {method} handleLogin(): void
        }

        class SignUpView <<Vue View>> {
            + form: Object
            + {method} handleRegister(): void
        }

        class ForgotPasswordView <<Vue View>> {
            + email: String
            + {method} handleReset(): void
        }

        class UsersManagementView <<Vue View>> {
            + filters: Object
            + activeTab: String
            + {method} changeRole(user, role): void
            + {method} createUser(): void
        }
    }

    IamStore --> IamApi : uses
}

' ===================================================================
' PROCUREMENT BOUNDED CONTEXT
' ===================================================================
package "Procurement" <<Rectangle>> #E8F5E9 {

    package "Domain" {
        class PurchaseOrder <<Entity>> {
            + id: Number
            + orderId: String
            + date: String
            + supplier: String
            + material: String
            + project: String
            + totalAmount: Number
            + status: String
            + quantity: Number
            + unit: String
            + unitPrice: Number
        }
    }

    package "Infrastructure" {
        class ProcurementApi extends BaseApi {
            - purchaseOrdersEndpoint: BaseEndpoint
            + {method} getPurchaseOrders(): Promise
            + {method} updateOrderStatus(id, data): Promise
        }

        class PurchaseOrderAssembler {
            + {static} toEntityFromResource(resource): PurchaseOrder
            + {static} toEntitiesFromResponse(response): PurchaseOrder[]
        }

        PurchaseOrderAssembler ..> PurchaseOrder : creates
    }

    package "Application" {
        class ProcurementStore <<Pinia Store>> {
            + purchaseOrders: PurchaseOrder[]
            + quotations: Object[]
            + isLoading: Boolean
            + {method} fetchPurchaseOrders(): Promise
            + {method} approvePO(id): Promise
            + {method} rejectPO(id): Promise
            + pendingOrders: PurchaseOrder[]
            + approvedOrders: PurchaseOrder[]
        }
    }

    package "Presentation" {
        class ApprovalInboxView <<Vue View>> {
            + activeTab: String
            + {method} approve(order): void
            + {method} reject(order): void
        }

        class QuotationsManagementView <<Vue View>> {
            + quotations: Object[]
            + {method} createQuotation(): void
        }
    }

    ProcurementStore --> ProcurementApi : uses
}

' ===================================================================
' REQUISITION BOUNDED CONTEXT
' ===================================================================
package "Requisition" <<Rectangle>> #E3F2FD {

    package "Domain" {
        class MaterialItem <<Entity>> {
            + id: Number
            + name: String
            + quantity: Number
            + unit: String
        }

        class Requisition <<Entity>> {
            + id: Number
            + projectId: Number
            + residentName: String
            + date: String
            + status: String
            + items: MaterialItem[]
        }

        Requisition "1" *-- "*" MaterialItem : contains
    }

    package "Infrastructure" {
        class RequisitionApi extends BaseApi {
            - materialsEndpoint: BaseEndpoint
            - requisitionsEndpoint: BaseEndpoint
            + {method} getMaterials(): Promise
            + {method} createRequisition(resource): Promise
        }

        class RequisitionAssembler {
            + {static} toEntityFromResource(resource): Requisition
            + {static} toEntitiesFromResponse(response): Requisition[]
        }

        RequisitionAssembler ..> Requisition : creates
    }

    package "Application" {
        class RequisitionStore <<Pinia Store>> {
            + materials: Object[]
            + requisitions: Requisition[]
            + {method} fetchMaterials(): Promise
            + {method} submitRequisition(data): Promise
        }
    }

    package "Presentation" {
        class MaterialRequestView <<Vue View>> {
            + form: Object
            + {method} handleSubmit(): void
        }

        class RequisitionInventoryView <<Vue View>> {
            + items: Object[]
            + filters: Object
        }
    }

    RequisitionStore --> RequisitionApi : uses
}

